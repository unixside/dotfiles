{
    // "layer": "top", // Waybar at top layer
    // "position": "bottom", // Waybar position (top|bottom|left|right)
    "height": 70, // Waybar height (to be removed for auto height)
    "width": 1920, // Waybar width
    "spacing": 10, // Gaps between modules (4px)
    //"margin-top": 8,
    //"margin-left": 8,
    //"margin-right": 8,
    //"margin-bottom": 8,
    // Choose the order of the modules
    "modules-left": ["image#artix", "hyprland/workspaces", "hyprland/window"],
    "modules-center": [],
    "modules-right": [ "cpu", "memory", "temperature", "pulseaudio", "network",  "backlight", "battery", "clock", "tray"],
    // Modules configuration
    "image#artix": {
    		  "path": "/home/lean/.config/waybar/logo-artix.png",
		  "size": 35,
    },
    "hyprland/workspaces": {
    "format": "{name}",
    "format-icons": {
    "1": "яДа",
    "2": "яЙи",
    "3": "яДб",
    "4": "яЖ╝",
    "5": "яБ╡",
    "active": "ґ░оп",
    "default": "ґ░Ка",
    "empty": "ґ░СК"
    },
            "persistent-workspaces": {
             "*": 5, // 5 workspaces by default on every monitor
             "HDMI-A-1": 3 // but only three on HDMI-A-1
       }
    },
    "keyboard-state": {
        "numlock": true,
        "capslock": true,
        "format": "{name} {icon}",
        "format-icons": {
            "locked": "яАг",
            "unlocked": "яВЬ"
        }
    },
    "hyprland/window": {
    "format": "яБФ {}",
    "rewrite": {
    "(.*) тАФ Mozilla Firefox": "ЁЯМО $1",
    "(.*) - zsh": "> [$1]",
    "wezterm" : "юЮХ $1"
    },
    "separate-outputs": true
    },
    "mpd": {
        "format": "{stateIcon} {consumeIcon}{randomIcon}{repeatIcon}{singleIcon}{artist} - {album} - {title} ({elapsedTime:%M:%S}/{totalTime:%M:%S}) т╕и{songPosition}|{queueLength}т╕й {volume}% яАБ",
        "format-disconnected": "Disconnected яАБ",
        "format-stopped": "{consumeIcon}{randomIcon}{repeatIcon}{singleIcon}Stopped яАБ",
        "unknown-tag": "N/A",
        "interval": 2,
        "consume-icons": {
            "on": "яГД "
        },
        "random-icons": {
            "off": "<span color=\"#f53c3c\">яБ┤</span> ",
            "on": "яБ┤ "
        },
        "repeat-icons": {
            "on": "яАЮ "
        },
        "single-icons": {
            "on": "яАЮ1 "
        },
        "state-icons": {
            "paused": "яБМ",
            "playing": "яБЛ"
        },
        "tooltip-format": "MPD (connected)",
        "tooltip-format-disconnected": "MPD (disconnected)"
    },
    "idle_inhibitor": {
        "format": "{icon}",
        "format-icons": {
            "activated": "яБо",
            "deactivated": "яБ░"
        }
    },
    "tray": {
        "icon-size": 28,
        "spacing": 5
    },
    "clock": {
        "timezone": "America/Buenos_Aires",
        "tooltip-format": "<big>{:%Y %B}</big>\n<tt><small>{calendar}</small></tt>",
        "format-alt": "{:%Y-%m-%d}"
    },
    "cpu": {
        "format": "яТ╝ {usage}%",
        "tooltip": false
    },
    "memory": {
        "format": "ю┐Е  {}%"
    },
    "temperature": {
        // "thermal-zone": 2,
        // "hwmon-path": "/sys/class/hwmon/hwmon2/temp1_input",
        "critical-threshold": 80,
        // "format-critical": " {icon} {temperatureC}┬░C ",
        "format": " {icon} {temperatureC}┬░C",
        "format-icons": ["яЛЛ","яЛК","яЛЙ","яЛИ","яЛЗ"]
    },
    "backlight": {
        // "device": "acpi_video1",
        "format": "{icon} {percent}%",
        "format-icons": ["юОН", "юПУ", "юПС", "юПП", "юПО", "юПН", "юПК", "юПИ", "юОЫ"]
    },
    "battery": {
        "states": {
            // "good": 95,
            "warning": 30,
            "critical": 15
        },
        "format": " {icon} {capacity}% ",
        "format-charging": "{icon} {capacity}% яГз ",
        "format-plugged": "{icon} {capacity}% яЗж ",
        "format-alt": "{icon} {time}",
        // "format-good": "", // An empty format will hide the module
        // "format-full": "",
        "format-icons": ["ґ░ВО","ґ░Б║","ґ░Б╗","ґ░Б╝","ґ░Б╜","ґ░Б╛","ґ░ВА","ґ░ВБ","ґ░ВВ","ґ░Б╣"]
    },
    "network": {
        // "interface": "wlp2*", // (Optional) To force the use of this interface
        "format-wifi": " яЗл  {signalStrength}% ",
        "format-ethernet": "{ipaddr}/{cidr} яЮЦ",
        "tooltip-format": "{ifname} via {gwaddr} яЮЦ",
        "format-linked": "{ifname} (No IP) яЮЦ",
        "format-disconnected": "ґ░Цк Disconnected",
        "format-alt": "{ifname}: {ipaddr}/{cidr}"
    },
    "pulseaudio": {
        // "scroll-step": 1, // %, can be a float
        "format": "{icon}  {volume}% {format_source}",
        "format-bluetooth": "{icon}яКФ {volume}% {format_source}",
        "format-bluetooth-muted": "яЪй {icon}яКФ {format_source}",
        "format-muted": " ю╗и  {format_source}",
        "format-source": "яД░ {volume}% ",
        "format-source-muted": "яД▒  ",
        "format-icons": {
            "headphone": " ю╣Ш ",
            "hands-free": " ю╣Щ ",
            "headset": " ю╣Щ ",
            "phone": " яВХ",
            "portable": " яВХ",
            "car": " яЖ╣",
            "default": [" яАж", " яАз", " яАи"]
        },
        "on-click": "wezterm start pulsemixer"
    },
    "custom/media": {
        "format": "{icon} {}",
        "return-type": "json",
        "max-length": 40,
        "format-icons": {
            "spotify": "яЖ╝",
            "default": "ЁЯОЬ"
        },
        "escape": true,
        "exec": "$HOME/.config/waybar/mediaplayer.py 2> /dev/null" // Script in resources folder
        // "exec": "$HOME/.config/waybar/mediaplayer.py --player spotify 2> /dev/null" // Filter player based on name
    }
}

